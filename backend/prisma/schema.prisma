// CLAMS Prisma schema — implements docs/02-database-schema.md
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------- Enums ----------------
enum UserRole {
  SUPER_ADMIN
  SITE_ADMIN
  WATCHMAN
  SUPERVISOR
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
  EXITED
  SUSPENDED
}

enum DeviceStatus {
  PENDING
  AUTHORIZED
  REVOKED
}

enum SessionState {
  OPEN
  CLOSED
  AUTO_CLOSED
  VOID
}

enum TapType {
  LOGIN
  LOGOUT
}

enum TapSource {
  NFC_UID
  NFC_NDEF
  QR
  MANUAL
}

enum VerificationMode {
  MANUAL
  AUTO
}

enum PhotoVerifyMode {
  ALWAYS
  NEVER
  RANDOM
}

enum CorrectionType {
  LOGIN
  LOGOUT
  MISSING
  WRONG_SITE
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CorrectionReason {
  FORGOT_CARD
  DEVICE_ISSUE
  NETWORK_ISSUE
  WRONG_SITE
  SUPERVISOR_MISTAKE
  OTHER
}

enum SyncEventStatus {
  ACCEPTED
  DUPLICATE
  CONFLICT
  REJECTED
}

enum CredentialKind {
  NFC_UID
  QR
}

// ---------------- Master data ----------------
model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  code      String   @unique
  timezone  String   @default("Asia/Kolkata")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  sites    Site[]
  vendors  Vendor[]
  users    User[]
  workers  Worker[]
  devices  Device[]

  @@map("organizations")
}

model Site {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  name            String
  code            String
  timezone        String   @default("Asia/Kolkata")
  latitude        Float?
  longitude       Float?
  geofenceRadiusM Int?     @map("geofence_radius_m")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  settings     SiteSettings?
  shifts       Shift[]
  devices      Device[]
  assignments  WorkerSiteAssignment[]
  sessions     AttendanceSession[] @relation("SessionSite")
  scopes       UserSiteScope[]

  @@unique([organizationId, code])
  @@map("sites")
}

model Vendor {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  code           String
  contactPerson  String?  @map("contact_person")
  contactNumber  String?  @map("contact_number")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  workers      Worker[]
  assignments  WorkerSiteAssignment[]

  @@unique([organizationId, code])
  @@map("vendors")
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  role           UserRole
  fullName       String    @map("full_name")
  email          String?   @unique
  phone          String?
  passwordHash   String    @map("password_hash")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization    @relation(fields: [organizationId], references: [id])
  siteScopes    UserSiteScope[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model UserSiteScope {
  userId String @map("user_id") @db.Uuid
  siteId String @map("site_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([userId, siteId])
  @@map("user_site_scopes")
}

model Device {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  siteId         String?      @map("site_id") @db.Uuid
  deviceUid      String       @map("device_uid")
  label          String?
  platform       String?
  status         DeviceStatus @default(PENDING)
  tokenHash      String?      @map("token_hash")
  authorizedBy   String?      @map("authorized_by") @db.Uuid
  authorizedAt   DateTime?    @map("authorized_at") @db.Timestamptz
  lastSeenAt     DateTime?    @map("last_seen_at") @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization     @relation(fields: [organizationId], references: [id])
  site         Site?            @relation(fields: [siteId], references: [id])
  taps         AttendanceTap[]

  @@unique([organizationId, deviceUid])
  @@map("devices")
}

// ---------------- Workers ----------------
model Worker {
  id                     String       @id @default(uuid()) @db.Uuid
  organizationId         String       @map("organization_id") @db.Uuid
  workerCode             String       @map("worker_code")
  nfcUid                 String?      @map("nfc_uid")
  qrIdentifier           String?      @map("qr_identifier")
  fullName               String       @map("full_name")
  fatherName             String?      @map("father_name")
  gender                 String?
  dateOfBirth            DateTime?    @map("date_of_birth") @db.Date
  language               String?
  photoUrl               String?      @map("photo_url")
  mobileNumber           String?      @map("mobile_number")
  pincode                String?
  bloodGroup             String?      @map("blood_group")
  emergencyContactName   String?      @map("emergency_contact_name")
  emergencyContactNumber String?      @map("emergency_contact_number")
  nomineeName            String?      @map("nominee_name")
  nomineeRelation        String?      @map("nominee_relation")
  vendorId               String?      @map("vendor_id") @db.Uuid
  natureOfContractor     String?      @map("nature_of_contractor")
  bankName               String?      @map("bank_name")
  bankAccountNumber      String?      @map("bank_account_number")
  ifscCode               String?      @map("ifsc_code")
  pfNumber               String?      @map("pf_number")
  esiNumber              String?      @map("esi_number")
  govIdType              String?      @map("gov_id_type")
  aadhaarCiphertext      Bytes?       @map("aadhaar_ciphertext")
  aadhaarLast4           String?      @map("aadhaar_last4")
  status                 WorkerStatus @default(ACTIVE)
  joinDate               DateTime?    @map("join_date") @db.Date
  exitDate               DateTime?    @map("exit_date") @db.Date
  notes                  String?
  createdAt              DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt              DateTime?    @map("deleted_at") @db.Timestamptz

  organization Organization           @relation(fields: [organizationId], references: [id])
  vendor       Vendor?                @relation(fields: [vendorId], references: [id])
  assignments  WorkerSiteAssignment[]
  credentials  WorkerCredential[]
  sessions     AttendanceSession[]
  taps         AttendanceTap[]
  corrections  CorrectionRequest[]

  @@unique([organizationId, workerCode])
  @@index([organizationId, mobileNumber])
  @@map("workers")
}

model WorkerSiteAssignment {
  id        String    @id @default(uuid()) @db.Uuid
  workerId  String    @map("worker_id") @db.Uuid
  siteId    String    @map("site_id") @db.Uuid
  vendorId  String?   @map("vendor_id") @db.Uuid
  startDate DateTime  @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  isPrimary Boolean   @default(true) @map("is_primary")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  worker Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site   Site    @relation(fields: [siteId], references: [id])
  vendor Vendor? @relation(fields: [vendorId], references: [id])

  @@map("worker_site_assignments")
}

model WorkerCredential {
  id        String         @id @default(uuid()) @db.Uuid
  workerId  String         @map("worker_id") @db.Uuid
  kind      CredentialKind
  value     String
  isActive  Boolean        @default(true) @map("is_active")
  issuedAt  DateTime       @default(now()) @map("issued_at") @db.Timestamptz
  revokedAt DateTime?      @map("revoked_at") @db.Timestamptz
  reason    String?

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_credentials")
}

// ---------------- Settings / shifts ----------------
model Shift {
  id                 String   @id @default(uuid()) @db.Uuid
  siteId             String   @map("site_id") @db.Uuid
  name               String
  startTime          DateTime @map("start_time") @db.Time
  endTime            DateTime @map("end_time") @db.Time
  isOvernight        Boolean  @default(false) @map("is_overnight")
  lateGraceMinutes   Int      @default(0) @map("late_grace_minutes")
  earlyGraceMinutes  Int      @default(0) @map("early_grace_minutes")
  otThresholdMinutes Int      @default(0) @map("ot_threshold_minutes")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  site             Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sessions         AttendanceSession[]
  defaultForSites  SiteSettings[]      @relation("DefaultShift")

  @@map("shifts")
}

model SiteSettings {
  siteId                     String           @id @map("site_id") @db.Uuid
  verificationMode           VerificationMode @default(MANUAL) @map("verification_mode")
  autoLoginCountdownSeconds  Int              @default(10) @map("auto_login_countdown_seconds")
  duplicateTapCooldownSeconds Int             @default(30) @map("duplicate_tap_cooldown_seconds")
  geoEnforcement             Boolean          @default(false) @map("geo_enforcement")
  geoRadiusMeters            Int              @default(200) @map("geo_radius_meters")
  photoVerificationMode      PhotoVerifyMode  @default(RANDOM) @map("photo_verification_mode")
  photoVerificationRandomPct Int              @default(20) @map("photo_verification_random_pct")
  defaultShiftId             String?          @map("default_shift_id") @db.Uuid
  updatedAt                  DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  site         Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  defaultShift Shift? @relation("DefaultShift", fields: [defaultShiftId], references: [id])

  @@map("site_settings")
}

// ---------------- Attendance ----------------
model AttendanceTap {
  id               String           @id @default(uuid()) @db.Uuid
  eventId          String           @map("event_id") @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  siteId           String           @map("site_id") @db.Uuid
  deviceId         String?          @map("device_id") @db.Uuid
  workerId         String?          @map("worker_id") @db.Uuid
  rawIdentifier    String?          @map("raw_identifier")
  tapSource        TapSource        @map("tap_source")
  tapType          TapType?         @map("tap_type")
  clientEventTime  DateTime         @map("client_event_time") @db.Timestamptz
  serverReceivedAt DateTime         @default(now()) @map("server_received_at") @db.Timestamptz
  monotonicMs      BigInt?          @map("monotonic_ms")
  latitude         Float?
  longitude        Float?
  geoAccuracyM     Float?           @map("geo_accuracy_m")
  verifiedMode     VerificationMode? @map("verified_mode")
  photoCapturedUrl String?          @map("photo_captured_url")
  isManualBackup   Boolean          @default(false) @map("is_manual_backup")
  manualReason     String?          @map("manual_reason")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz

  device       Device? @relation(fields: [deviceId], references: [id])
  worker       Worker? @relation(fields: [workerId], references: [id])
  loginSession  AttendanceSession? @relation("LoginTap")
  logoutSession AttendanceSession? @relation("LogoutTap")

  @@unique([organizationId, eventId])
  @@index([workerId, clientEventTime(sort: Desc)])
  @@index([siteId, serverReceivedAt(sort: Desc)])
  @@map("attendance_taps")
}

model AttendanceSession {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @map("organization_id") @db.Uuid
  workerId          String       @map("worker_id") @db.Uuid
  siteId            String       @map("site_id") @db.Uuid
  shiftId           String?      @map("shift_id") @db.Uuid
  workDate          DateTime     @map("work_date") @db.Date
  loginTapId        String?      @unique @map("login_tap_id") @db.Uuid
  logoutTapId       String?      @unique @map("logout_tap_id") @db.Uuid
  loginAt           DateTime     @map("login_at") @db.Timestamptz
  logoutAt          DateTime?    @map("logout_at") @db.Timestamptz
  state             SessionState @default(OPEN)
  workedMinutes     Int?         @map("worked_minutes")
  overtimeMinutes   Int?         @map("overtime_minutes")
  lateMinutes       Int?         @map("late_minutes")
  earlyLeaveMinutes Int?         @map("early_leave_minutes")
  logoutSiteId      String?      @map("logout_site_id") @db.Uuid
  isCrossSite       Boolean      @default(false) @map("is_cross_site")
  closedReason      String?      @map("closed_reason")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  worker      Worker              @relation(fields: [workerId], references: [id])
  site        Site                @relation("SessionSite", fields: [siteId], references: [id])
  shift       Shift?              @relation(fields: [shiftId], references: [id])
  loginTap    AttendanceTap?      @relation("LoginTap", fields: [loginTapId], references: [id])
  logoutTap   AttendanceTap?      @relation("LogoutTap", fields: [logoutTapId], references: [id])
  corrections CorrectionRequest[]

  @@index([workerId, workDate])
  @@index([siteId, workDate])
  @@map("attendance_sessions")
}

// ---------------- Corrections ----------------
model CorrectionRequest {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  workerId       String           @map("worker_id") @db.Uuid
  siteId         String           @map("site_id") @db.Uuid
  sessionId      String?          @map("session_id") @db.Uuid
  workDate       DateTime         @map("work_date") @db.Date
  type           CorrectionType
  reason         CorrectionReason
  notes          String?
  requestedBy    String           @map("requested_by") @db.Uuid
  status         CorrectionStatus @default(PENDING)
  reviewedBy     String?          @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?        @map("reviewed_at") @db.Timestamptz
  reviewNotes    String?          @map("review_notes")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  worker  Worker             @relation(fields: [workerId], references: [id])
  session AttendanceSession? @relation(fields: [sessionId], references: [id])
  items   CorrectionItem[]

  @@index([status, organizationId])
  @@map("correction_requests")
}

model CorrectionItem {
  id            String @id @default(uuid()) @db.Uuid
  requestId     String @map("request_id") @db.Uuid
  field         String
  proposedValue Json   @map("proposed_value")
  previousValue Json?  @map("previous_value")

  request CorrectionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("correction_items")
}

// ---------------- Audit ----------------
model AuditLog {
  id             BigInt   @id @default(autoincrement())
  organizationId String?  @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  actorRole      UserRole? @map("actor_role")
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id") @db.Uuid
  oldValue       Json?    @map("old_value")
  newValue       Json?    @map("new_value")
  reason         String?
  ipAddress      String?  @map("ip_address")
  deviceId       String?  @map("device_id") @db.Uuid
  requestId      String?  @map("request_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ---------------- Sync ----------------
model SyncBatch {
  id         String   @id @default(uuid()) @db.Uuid
  deviceId   String   @map("device_id") @db.Uuid
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz
  eventCount Int      @map("event_count")
  accepted   Int      @default(0)
  duplicates Int      @default(0)
  conflicts  Int      @default(0)
  rejected   Int      @default(0)

  events SyncEvent[]

  @@map("sync_batches")
}

model SyncEvent {
  id      String          @id @default(uuid()) @db.Uuid
  batchId String          @map("batch_id") @db.Uuid
  eventId String          @map("event_id") @db.Uuid
  status  SyncEventStatus
  detail  String?
  tapId   String?         @map("tap_id") @db.Uuid

  batch SyncBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("sync_events")
}

// ---------------- Auth ----------------
model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  familyId   String    @map("family_id") @db.Uuid
  tokenHash  String    @map("token_hash")
  deviceId   String?   @map("device_id") @db.Uuid
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  replacedBy String?   @map("replaced_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------- Reports ----------------
model ReportJob {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  requestedBy    String    @map("requested_by") @db.Uuid
  reportType     String    @map("report_type")
  format         String
  params         Json
  status         String    @default("QUEUED")
  resultUrl      String?   @map("result_url")
  error          String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  completedAt    DateTime? @map("completed_at") @db.Timestamptz

  @@map("report_jobs")
}
