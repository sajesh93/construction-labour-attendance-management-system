# ---------- Shared ----------
NODE_ENV=development

# ---------- PostgreSQL ----------
POSTGRES_USER=clams
POSTGRES_PASSWORD=clams_dev_password
POSTGRES_DB=clams
POSTGRES_PORT=5432
DATABASE_URL=postgresql://clams:clams_dev_password@localhost:5432/clams?schema=public

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---------- Object storage (MinIO / S3) ----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=clams
S3_FORCE_PATH_STYLE=true

# ---------- Backend / Auth ----------
API_PORT=3000
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=900            # seconds (15m)
JWT_REFRESH_TTL=2592000       # seconds (30d)

# ---------- Field encryption (Aadhaar etc.) ----------
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
DATA_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# ---------- Admin panel ----------
ADMIN_PORT=3100
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
ADMIN_SESSION_SECRET=change_me_admin_session_secret

# ---------- Seed super admin (first migration) ----------
SEED_SUPERADMIN_EMAIL=admin@clams.local
SEED_SUPERADMIN_PASSWORD=ChangeMe123!
SEED_ORG_NAME=Default Organization
SEED_ORG_CODE=DEFAULT
SEED_ORG_TIMEZONE=Asia/Kolkata
