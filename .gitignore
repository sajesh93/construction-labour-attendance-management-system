# Node
node_modules/
dist/
build/
coverage/
*.tsbuildinfo
.next/
out/

# Env / secrets
.env
.env.local
.env.*.local
infra/.env
# Firebase service-account key (server secret — NEVER commit; set as the API env var)
*firebase-adminsdk*.json
serviceAccount*.json
# Android release signing — keystore + credentials must NEVER be committed
*.jks
*.keystore
mobile/android/key.properties

# Android APK copied into the admin app for the /download endpoint
# (72MB binary — kept out of git; az acr build uploads it from the working tree)
admin/public/*.apk

# Prisma
backend/prisma/*.db
# Generated by the demo-open-sessions script (record of demo rows to undo)
backend/prisma/demo-open-sessions-ids.json

# Flutter / Dart
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/build/
mobile/.packages
mobile/ios/Pods/
mobile/android/.gradle/
*.g.dart
*.freezed.dart

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log

acrlog.txt
calog.txt

# Slide decks / scratch scripts (not part of the app)
*.pptx
*.py
deck/
outputs/

# Local DB backups — contain worker PII, never commit
backups/
